*.db
*.db-shm
*.db-wal
*.db.bak.*
era_data.db*
uploads/
exports/

# Secrets / env
.env
.env.local
rc-credentials.json
*.pem
*.key
*.json.gcp-cred

# Session exports / scratch
claude-session-*.md
scratch/

# Dev / test
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
tests/

# Docs
*.md

# Misc
.DS_Store
.git/
